# Copy to .env and fill in. .env is gitignored.
#
# Both scripts/validate.sh and scripts/seed.sh read this file when run locally.
# On Vercel, set the same variables in the project's Environment Variables
# (Project Settings -> Environment Variables).

# Numeric project id from the Flagsmith URL:
#   https://app.flagsmith.com/project/{ID}/environments/
FLAGSMITH_PROJECT_ID=

# Admin API token from Flagsmith UI:
#   Account icon -> Organisation settings -> API Tokens -> Create
# Secret. Do not commit. Do not put in client-side code.
FLAGSMITH_API_TOKEN=

# Override only for self-hosted Flagsmith. Leave unset for SaaS.
# FLAGSMITH_API_BASE=https://api.flagsmith.com/api/v1
